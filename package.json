{
  "name": "engram",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "postinstall": "pnpm run prisma:generate",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e:ui": "playwright test --ui",
    "ci:lint": "npm run lint",
    "ci:typecheck": "pnpm run prisma:generate && npm run typecheck",
    "ci:unit": "npm run test:unit",
    "ci:e2e": "npm run test:e2e",
    "ci:audit": "pnpm audit",
    "ci": "npm run ci:lint && npm run ci:typecheck && npm run ci:unit && npm run ci:e2e && npm run ci:audit"
  },
  "dependencies": {
    "@neondatabase/neon-js": "^0.1.0-beta.22",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^6.16.2",
    "@prisma/client": "^6.16.2",
    "next": ">=14.2.25 <15",
    "prisma": "^6.16.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.25",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.0",
    "vitest-mock-extended": "^3.1.0",
    "zod": "^3.24.2"
  }
}
